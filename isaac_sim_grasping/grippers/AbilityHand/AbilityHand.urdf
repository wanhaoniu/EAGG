      <origin xyz="-0.012 -0.010 0.097" rpy="1.780 -1.315 -1.811" />
      <limit lower="0.00" upper="1.74" effort="6.0" velocity="8.0677777442" />
      <!-- angles in rad, efforts in N-m, velocity in rad/s -->
